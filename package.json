{
  "name": "cc-notifier",
  "version": "0.1.0",
  "description": "Claude Code hook notifier for Feishu, WeCom, Ruliu, and generic webhooks.",
  "type": "module",
  "bin": {
    "cc-notifier": "bin/cc-notifier.js"
  },
  "files": [
    "bin",
    "dist/src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --test dist/test/*.test.js",
    "pretest": "npm run build",
    "prepack": "npm run build"
  },
  "keywords": [
    "claude-code",
    "claude",
    "hooks",
    "notifier",
    "notification",
    "feishu",
    "wecom",
    "ruliu",
    "webhook"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paihuai00/cc_cli_notifier.git"
  },
  "bugs": {
    "url": "https://github.com/paihuai00/cc_cli_notifier/issues"
  },
  "homepage": "https://github.com/paihuai00/cc_cli_notifier#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.5.0"
  }
}
